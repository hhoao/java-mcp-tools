{
    "compilerOptions": {
        "composite": true,
        "sourceMap": true,
        "target": "ES2023",
        "module": "CommonJS",
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    }
}
